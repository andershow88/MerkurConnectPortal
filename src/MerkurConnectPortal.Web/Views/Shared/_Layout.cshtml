<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MerkurConnectPortal</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/merkur.css" asp-append-version="true" />
    <script>
        (function () {
            var t = localStorage.getItem('mc-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
</head>
<body class="mc-body">

    <!-- Sidebar -->
    <nav class="mc-sidebar" id="sidebar">
        <div class="mc-sidebar-brand">
            <div class="mc-logo">
                <img src="~/images/merkur-logo.svg" alt="Merkur Privatbank KGaA" class="mc-logo-img" />
                <div>
                    <div class="mc-logo-title">MerkurConnectPortal</div>
                    <div class="mc-logo-subtitle">MERKUR PRIVATBANK KGaA</div>
                </div>
            </div>
        </div>

        <div class="mc-sidebar-bank">
            <div class="mc-sidebar-bank-label">Angemeldet als</div>
            <div class="mc-sidebar-bank-name">@User.FindFirst("PartnerBankName")?.Value</div>
            <div class="mc-sidebar-bank-user"><i class="bi bi-person-circle me-1"></i>@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</div>
        </div>

        <ul class="mc-nav">
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Objekte" ? "active" : "")"
                   asp-controller="Objekte" asp-action="Index">
                    <i class="bi bi-buildings"></i>
                    <span>Objekte</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dokumente" ? "active" : "")"
                   asp-controller="Dokumente" asp-action="Index">
                    <i class="bi bi-folder2-open"></i>
                    <span>Dokumente</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Hilfe" ? "active" : "")"
                   asp-controller="Hilfe" asp-action="Index">
                    <i class="bi bi-question-circle"></i>
                    <span>Hilfe & Kontakt</span>
                </a>
            </li>
        </ul>

        <div class="mc-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="mc-logout-btn">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Abmelden</span>
                </button>
            </form>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="mc-main" id="main-content">
        <!-- Top Bar -->
        <header class="mc-topbar" style="gap:.75rem;">
            <button class="mc-sidebar-toggle d-lg-none" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>

            <!-- ── KI-Suchleiste ── -->
            <div style="flex:1; display:flex; align-items:center; gap:.7rem;
                        background:var(--mc-bg); border:1.5px solid var(--mc-border);
                        border-radius:26px; padding:.45rem .55rem .45rem 1.1rem;
                        transition:border-color .2s; min-width:0;"
                 id="aiSearchBar"
                 onfocusin="this.style.borderColor='var(--mc-gold)'"
                 onfocusout="this.style.borderColor='var(--mc-border)'">
                <i class="bi bi-stars" style="color:var(--mc-gold); font-size:1.05rem; flex-shrink:0;"></i>
                <input id="aiTopbarEingabe" type="text"
                       placeholder="Frag den KI-Assistenten… (z.B. &quot;Zeig aktuelle Objekte&quot;)"
                       style="flex:1; border:none; background:transparent; color:var(--mc-text);
                              font-size:.9rem; outline:none; min-width:0; font-family:inherit;"
                       onkeydown="aiTopbarKeydown(event)" />
                <kbd style="font-size:.68rem; color:var(--mc-text-muted); background:var(--mc-surface);
                            border:1px solid var(--mc-border); border-radius:5px; padding:1px 6px;
                            flex-shrink:0;" class="d-none d-md-inline">Enter</kbd>
            </div>

            <div class="mc-topbar-right" style="flex-shrink:0;">
                <span class="mc-topbar-date d-none d-md-inline">
                    <i class="bi bi-calendar3 me-1"></i>
                    @DateTime.Now.ToString("dd.MM.yyyy")
                </span>
                <div id="partnerNotifBell" class="mc-notif-bell" title="Neue Benachrichtigungen von Merkur Privatbank" style="display:none; cursor:pointer;"
                     onclick="window.location.href='/Dashboard/Aktivitaeten'">
                    <i class="bi bi-bell-fill"></i>
                    <span id="partnerNotifCount" class="mc-notif-count">0</span>
                </div>
                <button class="mc-theme-toggle" id="themeToggle" title="Erscheinungsbild wechseln" aria-label="Erscheinungsbild wechseln">
                    <i id="themeIcon" class="bi bi-sun-fill"></i>
                </button>
            </div>
        </header>

        <!-- ── KI-Assistent Modal ──────────────────────────────────────── -->
        <div id="aiModal" style="display:none; position:fixed; inset:0; z-index:1000; align-items:flex-start; justify-content:center; padding-top:70px;">
            <div onclick="aiSchliessen()" style="position:absolute; inset:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(3px);"></div>
            <div style="position:relative; width:min(720px,96vw); max-height:calc(100vh - 90px);
                        background:var(--mc-surface); border-radius:16px;
                        box-shadow:0 30px 70px rgba(0,0,0,0.3); display:flex;
                        flex-direction:column; overflow:hidden; border:1px solid var(--mc-border);">

                <div style="padding:.85rem 1.2rem; background:linear-gradient(135deg,#16213e 0%,#1a2a50 100%);
                            display:flex; align-items:center; gap:.7rem; flex-shrink:0;">
                    <i class="bi bi-stars" style="font-size:1.2rem; color:#c9a84c;"></i>
                    <div style="flex:1;">
                        <div style="font-weight:700; color:#fff; font-size:.9rem;">MerkurConnect KI-Assistent</div>
                        <div style="font-size:.7rem; color:rgba(255,255,255,.5);">Objekte · Dokumente · Nachrichten · Software-Fragen</div>
                    </div>
                    <button onclick="aiSchliessen()" title="Schließen (Esc)"
                            style="background:none; border:none; color:rgba(255,255,255,.55);
                                   cursor:pointer; font-size:1.4rem; padding:0; line-height:1;">&times;</button>
                </div>

                <div id="aiVerlauf" style="flex:1; overflow-y:auto; padding:1rem 1.2rem;
                                           display:flex; flex-direction:column; gap:.75rem;
                                           min-height:120px; max-height:55vh;">
                </div>

                <div style="padding:.75rem 1.1rem; border-top:1px solid var(--mc-border);
                            background:var(--mc-surface); flex-shrink:0;">
                    <div style="display:flex; gap:.5rem; align-items:center;">
                        <i class="bi bi-stars" style="color:var(--mc-gold); font-size:.9rem; flex-shrink:0;"></i>
                        <input id="aiModalEingabe" type="text"
                               placeholder="Folgefrage stellen… (Enter senden)"
                               style="flex:1; border:1px solid var(--mc-border); border-radius:8px;
                                      padding:.5rem .8rem; font-size:.86rem; background:var(--mc-bg);
                                      color:var(--mc-text); outline:none; font-family:inherit; transition:border-color .2s;"
                               onfocus="this.style.borderColor='var(--mc-gold)'"
                               onblur="this.style.borderColor='var(--mc-border)'"
                               onkeydown="aiModalKeydown(event)" />
                        <button onclick="aiSendenAusModal()"
                                style="background:linear-gradient(135deg,#16213e,#1a3a6e); color:#fff;
                                       border:none; border-radius:8px; padding:.5rem 1rem;
                                       cursor:pointer; font-size:.83rem; font-weight:600;
                                       display:flex; align-items:center; gap:.35rem; flex-shrink:0;">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div style="font-size:.68rem; color:var(--mc-text-muted); margin-top:.35rem; padding-left:1.4rem;">
                        Powered by OpenAI · Objekt-/Dokument-/Nachrichten-Daten Ihrer Partnerbank werden einbezogen
                    </div>
                </div>
            </div>
        </div>

        <!-- Page Content -->
        <main class="mc-content">
            @if (TempData["Erfolgsmeldung"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Erfolgsmeldung"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Fehlermeldung"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Fehlermeldung"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>

        <footer class="mc-footer">
            <span>&copy; @DateTime.Now.Year Merkur Privatbank KGaA – MerkurConnectPortal v1.0 MVP</span>
            <span class="ms-3 text-muted small">Vertraulich – Nur für autorisierte Partnerbanken</span>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/merkur.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        // ── Partnerbank-Benachrichtigungs-Polling ────────────────────────────────
        (function () {
            var vorherAnzahl = -1;

            function aktualisierePartnerBadge() {
                fetch('/Dashboard/UngeleseneAnzahlJson', { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (data) {
                        if (!data) return;
                        var bell = document.getElementById('partnerNotifBell');
                        var count = document.getElementById('partnerNotifCount');
                        if (!bell || !count) return;

                        if (data.anzahl > 0) {
                            count.textContent = data.anzahl;
                            bell.style.display = 'flex';
                            if (vorherAnzahl >= 0 && data.anzahl > vorherAnzahl) {
                                bell.classList.remove('mc-notif-pulse');
                                void bell.offsetWidth; // reflow
                                bell.classList.add('mc-notif-pulse');
                            }
                        } else {
                            bell.style.display = 'none';
                        }
                        vorherAnzahl = data.anzahl;
                    })
                    .catch(function () { /* Fehler ignorieren */ });
            }

            aktualisierePartnerBadge();
            setInterval(aktualisierePartnerBadge, 30000);
        })();
    </script>

    <script>
        // ── KI-Assistent ──────────────────────────────────────────────────
        let aiVerlauf = [];

        function aiOeffnen() {
            const modal = document.getElementById('aiModal');
            modal.style.display = 'flex';
            setTimeout(() => document.getElementById('aiModalEingabe')?.focus(), 80);
        }

        function aiSchliessen() {
            const m = document.getElementById('aiModal');
            if (m) m.style.display = 'none';
            const tb = document.getElementById('aiTopbarEingabe');
            if (tb) tb.value = '';
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') aiSchliessen();
        });

        function aiTopbarKeydown(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                const frage = document.getElementById('aiTopbarEingabe').value.trim();
                if (!frage) return;
                aiVerlauf = [];
                document.getElementById('aiVerlauf').innerHTML = '';
                aiOeffnen();
                aiSenden(frage);
            }
        }

        function aiModalKeydown(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                aiSendenAusModal();
            }
        }

        function aiSendenAusModal() {
            const inp = document.getElementById('aiModalEingabe');
            const frage = inp.value.trim();
            if (!frage) return;
            inp.value = '';
            aiSenden(frage);
        }

        function aiMarkdown(text) {
            return text
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.+?)\*/g, '<em>$1</em>')
                .replace(/`(.+?)`/g, '<code>$1</code>')
                .replace(/^#{1,3}\s+(.+)$/gm, '<strong>$1</strong>')
                .replace(/^[-*]\s+(.+)$/gm, '<li>$1</li>')
                .replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`)
                .replace(/\n\n+/g, '</p><p>')
                .replace(/\n/g, '<br>')
                .replace(/^(?!<)(.+)/, '<p>$1</p>');
        }

        function aiNachrichtAppend(rolle, html) {
            const verlauf = document.getElementById('aiVerlauf');
            const div = document.createElement('div');
            div.className = `ai-msg ai-msg-${rolle}`;
            div.innerHTML = `<div class="ai-msg-bubble">${html}</div>`;
            verlauf.appendChild(div);
            verlauf.scrollTop = verlauf.scrollHeight;
            return div;
        }

        async function aiSenden(frage) {
            if (!frage) return;
            aiNachrichtAppend('user', aiMarkdown(frage));

            const verlaufEl = document.getElementById('aiVerlauf');
            const typing = document.createElement('div');
            typing.className = 'ai-msg ai-msg-assistant';
            typing.innerHTML = '<div class="ai-typing"><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><span>Wird geladen…</span></div>';
            verlaufEl.appendChild(typing);
            verlaufEl.scrollTop = verlaufEl.scrollHeight;

            try {
                const res = await fetch('/AiAssistent/Fragen', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ frage, verlauf: aiVerlauf })
                });
                const data = await res.json();
                verlaufEl.removeChild(typing);

                if (data.error) {
                    aiNachrichtAppend('assistant',
                        `<span style="color:#e74c3c;"><i class="bi bi-exclamation-triangle"></i> ${data.error}</span>`);
                } else {
                    aiVerlauf.push({ rolle: 'user', text: frage });
                    aiVerlauf.push({ rolle: 'assistant', text: data.antwort });
                    if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
                    aiNachrichtAppend('assistant', aiMarkdown(data.antwort));
                }
            } catch {
                verlaufEl.removeChild(typing);
                aiNachrichtAppend('assistant',
                    '<span style="color:#e74c3c;">Verbindungsfehler. Bitte versuche es erneut.</span>');
            } finally {
                document.getElementById('aiModalEingabe')?.focus();
            }
        }
    </script>
</body>
</html>
