@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fehler – MerkurConnect Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: #f0f3f8; display:flex; align-items:center; justify-content:center; min-height:100vh; font-family:'Segoe UI',sans-serif; }
        .error-box { background:#fff; border-radius:12px; padding:3rem 2.5rem; text-align:center; box-shadow:0 4px 24px rgba(13,30,64,0.12); max-width:480px; width:100%; }
        .error-icon { font-size:3rem; color:#dc2626; margin-bottom:1rem; }
    </style>
</head>
<body>
    <div class="error-box">
        <div class="error-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        <h1 style="font-size:1.4rem; font-weight:700; color:#0d1e40; margin-bottom:0.5rem;">Ein Fehler ist aufgetreten</h1>
        <p class="text-muted mb-3" style="font-size:0.88rem;">Es tut uns leid, aber es ist ein unerwarteter Fehler aufgetreten. Bitte versuchen Sie es erneut oder kontaktieren Sie den Support.</p>
        <a href="/" class="btn btn-primary" style="background:#0d1e40; border:none; font-size:0.88rem;">
            <i class="bi bi-house me-1"></i> Zur Startseite
        </a>
    </div>
</body>
</html>
