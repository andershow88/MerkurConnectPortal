<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MerkurConnectPortal – Administration</title>
    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/merkur.css" asp-append-version="true" />
    <script>
        (function () {
            var t = localStorage.getItem('mc-theme') || 'light';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <style>
        .mc-admin-badge {
            background: #c0392b;
            color: #fff;
            font-size: 0.6rem;
            font-weight: 700;
            padding: 0.15rem 0.45rem;
            border-radius: 4px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            vertical-align: middle;
            margin-left: 0.4rem;
        }
        .mc-sidebar { border-right-color: #c0392b22; }
        .mc-sidebar-brand { border-bottom-color: #c0392b33; }
        .mc-nav-link.active { border-left-color: #c0392b; }
        .admin-notif-badge {
            background: #c0392b;
            color: white;
            border-radius: 50%;
            font-size: 0.65rem;
            font-weight: 700;
            min-width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            margin-left: auto;
        }
    </style>
</head>
<body class="mc-body">

    <!-- Sidebar -->
    <nav class="mc-sidebar" id="sidebar">
        <div class="mc-sidebar-brand">
            <div class="mc-logo">
                <img src="~/images/merkur-logo.svg" alt="Merkur Privatbank KGaA" class="mc-logo-img" />
                <div>
                    <div class="mc-logo-title">
                        MerkurConnectPortal
                        <span class="mc-admin-badge">Admin</span>
                    </div>
                    <div class="mc-logo-subtitle">MERKUR PRIVATBANK KGaA</div>
                </div>
            </div>
        </div>

        <div class="mc-sidebar-bank">
            <div class="mc-sidebar-bank-label">Angemeldet als Bankmitarbeiter</div>
            <div class="mc-sidebar-bank-name">Merkur Privatbank KGaA</div>
            <div class="mc-sidebar-bank-user">
                <i class="bi bi-shield-fill-check me-1" style="color:#c0392b;"></i>
                @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
            </div>
        </div>

        <ul class="mc-nav">
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   asp-controller="Admin" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>Übersicht</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Objekte" || ViewContext.RouteData.Values["action"]?.ToString() == "ObjektDetail" ? "active" : "")"
                   asp-controller="Admin" asp-action="Objekte">
                    <i class="bi bi-buildings"></i>
                    <span>Alle Objekte</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dokumente" || ViewContext.RouteData.Values["action"]?.ToString() == "DokumentUpload" ? "active" : "")"
                   asp-controller="Admin" asp-action="Dokumente">
                    <i class="bi bi-folder2-open"></i>
                    <span>Dokumente</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Aktivitaeten" ? "active" : "")"
                   asp-controller="Admin" asp-action="Aktivitaeten">
                    <i class="bi bi-bell"></i>
                    <span>Aktivitäten</span>
                    @{
                        var ungelesen = ViewBag.UngeleseneAnzahl as int?;
                        if (ungelesen > 0)
                        {
                            <span class="admin-notif-badge">@ungelesen</span>
                        }
                    }
                </a>
            </li>
        </ul>

        <div class="mc-sidebar-footer">
            <form asp-controller="Admin" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="mc-logout-btn">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Abmelden</span>
                </button>
            </form>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="mc-main" id="main-content">
        <header class="mc-topbar">
            <button class="mc-sidebar-toggle d-lg-none" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>
            <div class="mc-breadcrumb">
                @if (ViewData["Breadcrumb"] != null)
                {
                    @Html.Raw(ViewData["Breadcrumb"])
                }
            </div>
            <div class="mc-topbar-right">
                <span class="mc-topbar-date">
                    <i class="bi bi-calendar3 me-1"></i>
                    @DateTime.Now.ToString("dd.MM.yyyy")
                </span>
                <button class="mc-theme-toggle" id="themeToggle" title="Erscheinungsbild wechseln" aria-label="Erscheinungsbild wechseln">
                    <i id="themeIcon" class="bi bi-sun-fill"></i>
                </button>
            </div>
        </header>

        <main class="mc-content">
            @if (TempData["Erfolgsmeldung"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Erfolgsmeldung"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Fehlermeldung"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Fehlermeldung"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>

        <footer class="mc-footer">
            <span>&copy; @DateTime.Now.Year Merkur Privatbank KGaA – MerkurConnectPortal v1.0 MVP</span>
            <span class="ms-3 text-muted small">Administration – Nur für autorisierte Bankmitarbeiter</span>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/merkur.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
